DATABASE_URL=postgresql://werkstatt:changeme_dev@db:5432/werkstattclone
JWT_ACCESS_SECRET=dev-access-secret-min-32-chars-xyz-abc
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-chars-xyz-abc
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/appointments/auth/google/callback

# Email (SMTP) — required for invoice send and appointment reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="WerkstattClone <noreply@example.com>"
