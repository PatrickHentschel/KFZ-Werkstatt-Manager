{
  "name": "werkstattclone",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*", "backend", "frontend"],
  "scripts": {
    "dev": "docker-compose up",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=backend && npm run build --workspace=frontend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend"
  }
}
